# Docker Compose Environment Variables
# Copy this file to .env and customize for your environment

# Application version (used for Docker build)
VERSION=dev
COMMIT=unknown
BUILD_DATE=

# Arcade configuration via environment variables
# These override values in config.yaml

# Network: main, test, or stn
ARCADE_NETWORK=main

# Log level: debug, info, warn, error
ARCADE_LOG_LEVEL=info

# Teranode DataHub URLs (comma-separated, format: <url>/api/v1) - used for tx submission and block/subtree data
# ARCADE_TERANODE_DATAHUB_URLS=https://teranode.example.com/api/v1

# Server address (usually don't change this in Docker)
# ARCADE_SERVER_ADDRESS=:3011

# Authentication (if enabled)
# ARCADE_AUTH_ENABLED=false
# ARCADE_AUTH_TOKEN=your-secret-token

# Storage path (usually don't change this in Docker)
# ARCADE_STORAGE_PATH=/data
